@model CreateCourseCategoryDto
@{
    ViewData["Title"] = "Kurs Kategori Oluşturma Sayfası";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<form method="post">
    <label>Kurs Kategori Adı</label>
    <input type="text" asp-for="Name" class="form-control" />
    <br />
    <label>Açıklama</label>
    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    <br />
    <label>İkon</label>
    <input type="text" asp-for="Icon" class="form-control" />
    <br />
    <label>Ana Sayfada Gösterilsin    </label>
    <input type="checkbox" asp-for="IsShown" class="form-check" />
    <br />

    <button class="btn btn-outline-primary" type="submit">Kaydet</button>
</form>